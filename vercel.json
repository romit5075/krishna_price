{
  "name": "krishna-price",
  "version": 2,
  "public": false,
  "buildCommand": "echo 'No build step required'",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/price.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
